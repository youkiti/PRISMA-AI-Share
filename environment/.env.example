# Copy this file to `.env` and replace the placeholder values with your own.
# Do NOT commit real API keys or secrets to version control.

# Adobe PDF Services (used by pdf_preprocessing/*04_pdf_to_json.py)
PDF_SERVICES_CLIENT_ID=your_adobe_client_id
PDF_SERVICES_CLIENT_SECRET=your_adobe_client_secret

# LLM provider keys (used by prisma_evaluator CLI when rerunning experiments)
OPENROUTER_API_KEY=your_openrouter_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GEMINI_API_KEY=your_gemini_key

# Optional runtime controls
PRISMA_EVALUATOR_MAX_WORKERS=1
GPT_OSS_MAX_TOKENS=60000
